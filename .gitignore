.DS_Store
**/.terraform/
terraform/.terraform.lock.hcl
# Terraform state contains cluster secrets (PKI, bootstrap tokens, kubeconfig) — never commit
**/*.tfstate
**/*.tfstate.*
# Saved plan files may embed variable values/secrets
**/*.tfplan
**/tfplan
configs/services/homepage/logs/homepage.log
apps/traefik/letsencrypt/acme.json
data

# Secrets — never commit
*.env
!*.env.example
*.tfvars
!*.tfvars.example
# конфиг кластеров (без секретов) трекаем; секреты — в *.auto.tfvars или ENV
!**/terraform.tfvars
secrets/
*.key
*.pem
kubeconfig
talosconfig
# sandbox-эксперименты с секретами — не коммитим (для реальных: SealedSecrets/ExternalSecrets)
sandbox/secret.yaml

# Local tooling
.claude/
.DS_Store
