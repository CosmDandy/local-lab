services:
  databasus:
    container_name: databasus
    image: "{{ databasus_image }}:{{ databasus_version }}"
    ports:
      - "{{ databasus_port }}:4005"
    volumes:
      - "{{ databasus_data_dir }}:/databasus-data"
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "databasus", "healthcheck"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 60s
